# Widerstands-Toolkit Environment Variables
# ==========================================
# Kopiere diese Datei zu .env und fülle die Werte aus.
# NIEMALS .env ins Git committen!

# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=1

# Security - generiere einen eigenen Key mit: python -c "import os; print(os.urandom(32).hex())"
SECRET_KEY=your-secret-key-here-generate-a-new-one

# Database (optional, für zukünftige Features)
# DATABASE_URL=sqlite:///data.db

# Production Settings (wenn deployt)
# FLASK_ENV=production
# FLASK_DEBUG=0
